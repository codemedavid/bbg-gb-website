# Supabase Postgres — Project Settings > Database > Connection string (Transaction pooler)
DATABASE_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Supabase API — Project Settings > API
SUPABASE_URL=https://[ref].supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
# Auth
JWT_SECRET=change-me-to-a-long-random-string
# Storage: 'local' (dev, ./uploads) or 'supabase' (prod, Supabase Storage buckets)
STORAGE_DRIVER=supabase
# Email: leave SMTP_* empty to log emails to console + ./server/email-log
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM="BBG Peptides <noreply@bbgpeptides.ph>"
# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
NODE_ENV=development
