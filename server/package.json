    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
