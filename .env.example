# Root reference — real values live in .env (git-ignored).
# On Vercel, set these in Project Settings > Environment Variables:
#   DATABASE_URL, JWT_SECRET, STORAGE_DRIVER (+ its credentials below),
#   SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, MAIL_FROM, CLIENT_ORIGIN
#
# ---- File uploads (QR codes, payment proofs, COA files) ----------------
# STORAGE_DRIVER selects where uploads go: imagekit | supabase | local (./uploads)
#
# REQUIRED IN PRODUCTION. 'local' writes to the server filesystem, which is
# read-only on serverless hosts — every QR upload (and therefore every "add
# payment method", since a new method needs a QR) fails there with a 503
# naming this variable.
#
# Leaving STORAGE_DRIVER unset auto-detects from whichever credentials are
# present: ImageKit wins, then Supabase, then local. Setting it explicitly is
# still recommended so a missing key fails loudly instead of downgrading.
STORAGE_DRIVER=imagekit
#
# ImageKit.io (STORAGE_DRIVER=imagekit) — files land under /bbg-groupbuy/<bucket>:
#   IMAGEKIT_PUBLIC_KEY=public_xxxxx
#   IMAGEKIT_PRIVATE_KEY=private_xxxxx        # server-only secret
#   IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_id
#
# Supabase Storage (STORAGE_DRIVER=supabase):
#   SUPABASE_URL=https://<ref>.supabase.co    # falls back to NEXT_PUBLIC_SUPABASE_URL
#   SUPABASE_SERVICE_KEY=xxxxx                # server-only secret

# ---- PostHog (order notification events) -------------------------------
# The app emits one server-side event per order status change; a PostHog
# destination sends the customer's Gmail off each event. See docs/posthog-events.md
# for the event names and property schema.
# Unset = capture is skipped (valid local/dev state), so no emails go out.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
